# Get your free API key at https://www.football-data.org/client/register
# Free tier supports 10 requests/minute — enough for 30-second polling.
FOOTBALL_API_KEY=your_api_key_here

# Competition code for the 2026 FIFA World Cup.
# Verify at https://api.football-data.org/v4/competitions after signing up.
# The 2022 World Cup used "WC2022"; the 2026 edition likely follows the same pattern.
COMPETITION_CODE=WC2026
